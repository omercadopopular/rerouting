@article{gabaix_granular_2011,
	title = {The {Granular} {Origins} of {Aggregate} {Fluctuations}},
	volume = {79},
	issn = {0012-9682},
	url = {http://doi.wiley.com/10.3982/ECTA8769},
	doi = {10.3982/ECTA8769},
	abstract = {This paper proposes that idiosyncratic ﬁrm-level shocks can explain an important part of aggregate movements and provide a microfoundation for aggregate shocks. Existing research has focused on using aggregate shocks to explain business cycles, arguing that individual ﬁrm shocks average out in the aggregate. I show that this argument breaks down if the distribution of ﬁrm sizes is fat-tailed, as documented empirically. The idiosyncratic movements of the largest 100 ﬁrms in the United States appear to explain about one-third of variations in output growth. This “granular” hypothesis suggests new directions for macroeconomic research, in particular that macroeconomic questions can be clariﬁed by looking at the behavior of large ﬁrms. This paper’s ideas and analytical results may also be useful for thinking about the ﬂuctuations of other economic aggregates, such as exports or the trade balance.},
	language = {en},
	number = {3},
	urldate = {2020-09-23},
