	pages = {237--254},
}

@article{menon_international_2009,
	title = {International {Trade} and the {Gender} {Wage} {Gap}: {New} {Evidence} from {India}’s {Manufacturing} {Sector}},
	volume = {37},
	issn = {0305-750X},
	shorttitle = {International {Trade} and the {Gender} {Wage} {Gap}},
	url = {https://www.sciencedirect.com/science/article/pii/S0305750X08003197},
	doi = {10.1016/j.worlddev.2008.09.009},
	abstract = {This study examines how increasing competitive forces from India’s trade liberalization have affected women’s relative wages and employment. Neoclassical theory implies that costly discrimination against female workers should diminish over time with increased competition. We incorporate this idea into a theoretical model of competition and industry concentration and test the model using repeated cross-sections of India’s National Sample Survey Organization (NSSO) household survey data merged with trade and production data from 1983 to 2004. Estimates from ordinary least-squares (OLS) and fixed effects regressions at the industry-level indicate that increasing openness to trade is associated with larger wage gaps in India’s concentrated manufacturing industries.},
	number = {5},
	urldate = {2023-12-18},
	journal = {World Development},
	author = {Menon, Nidhiya and Rodgers, Yana van der Meulen},
	month = may,
	year = {2009},
	keywords = {Asia, India, competition, discrimination, gender wage gap, trade liberalization},
	pages = {965--981},
}

