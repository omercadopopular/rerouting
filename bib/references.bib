	url = {https://www.aeaweb.org/articles?id=10.1257/aer.20141743},
	doi = {10.1257/aer.20141743},
	abstract = {We develop a quantifiable general equilibrium model of trade and multinational production (MP) in which countries can specialize in innovation or production. Home market effects or comparative advantage leads some countries to specialize in innovation and relegate manufacturing operations to other countries via outward MP. Counterfactual analysis reveals that the reduction in the cost of MP or the integration of China into the world economy may hurt countries that are driven to specialize in production, although these losses tend to be very small. Contrary to popular fears, production workers gain even in countries that further specialize in innovation.},
	language = {en},
	number = {8},
