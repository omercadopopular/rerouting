	shorttitle = {Trading {Tasks}},
	url = {https://www.aeaweb.org/articles?id=10.1257/aer.98.5.1978},
	doi = {10.1257/aer.98.5.1978},
	abstract = {We propose a theory of the global production process that focuses on tradeable
tasks, and use it to study how falling costs of offshoring affect factor prices in
