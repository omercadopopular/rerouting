@article{gaddis_gendered_2017,
	title = {The {Gendered} {Labor} {Market} {Impacts} of {Trade} {Liberalization}: {Evidence} from {Brazil}},
	volume = {52},
	issn = {0022-166X},
	shorttitle = {The {Gendered} {Labor} {Market} {Impacts} of {Trade} {Liberalization}},
	url = {https://www.jstor.org/stable/26450452},
	abstract = {This paper investigates the impact of Brazil's trade liberalization on gender differences in labor market outcomes, using difference-in-difference estimation that exploits variation in preliberalization industry composition across microregions. We find that trade liberalization reduced male and female labor force participation rates and tradable sector employment rates, particularly among the low-skilled population. As aggregate effects on men are significantly larger, liberalization reduced the percentage point gender gap in employment and participation rates. However, in proportionate terms, we find no evidence that women's employment and participation increased relative to men's, or that women benefitted from the procompetitive effects of free trade.},
	number = {2},
	urldate = {2023-12-18},
	journal = {The Journal of Human Resources},
	author = {Gaddis, Isis and Pieters, Janneke},
	year = {2017},
