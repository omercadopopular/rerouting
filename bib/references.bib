@article{alloza_dynamic_2020,
	title = {Dynamic {Effects} of {Persistent} {Shocks}},
	url = {http://arxiv.org/abs/2006.14047},
	abstract = {We provide evidence that many narrative shocks used by prominent literature are persistent. We show that the two leading methods to estimate impulse responses to an independently identiﬁed shock (local projections and distributed lag models) treat persistence diﬀerently, hence identifying diﬀerent objects. We propose corrections to re-establish the equivalence between local projections and distributed lag models, providing applied researchers with methods and guidance to estimate their desired object of interest. We apply these methods to well-known empirical work and ﬁnd that how persistence is treated has a sizable impact on the estimates of dynamic eﬀects.},
	language = {en},
	urldate = {2021-05-03},
	journal = {arXiv:2006.14047 [econ, q-fin]},
	author = {Alloza, Mario and Gonzalo, Jesus and Sanz, Carlos},
