@article{felix_trade_2022,
	title = {Trade, {Labor} {Market} {Concentration}, and {Wages}},
	abstract = {I estimate the eﬀect of trade on local labor market concentration and the consequences thereof to wages using a suﬃcient statistics approach, employer-employee linked data, and tariﬀ shocks from Brazil’s trade liberalization. Trade increased concentration by 7\%, an eﬀect driven by ﬁrm exit and labor reallocation towards exporters. Increased concentration raised wage markdowns—estimated at 50 cents on the dollar pre-shock—by enough to oﬀset small wage gains from reallocation, but on net did not meaningfully reduce wages. Most of the wage decline due to trade was driven instead by reductions in the marginal revenue product of labor.},
	language = {en},
	author = {Felix, Mayara},
	year = {2022},
}

