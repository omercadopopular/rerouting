@article{chernozhukov_distribution_2020,
	title = {Distribution {Regression} with {Sample} {Selection}, with an {Application} to {Wage} {Decompositions} in the {UK}},
	url = {http://arxiv.org/abs/1811.11603},
	abstract = {We develop a distribution regression model under endogenous sample selection. This model is a semiparametric generalization of the Heckman selection model that accommodates much richer patterns of heterogeneity in the selection process and eﬀect of the covariates. The model applies to continuous, discrete and mixed outcomes. We study the identiﬁcation of the model, and develop a computationally attractive two-step method to estimate the model parameters, where the ﬁrst step is a probit regression for the selection equation and the second step consists of multiple distribution regressions with selection corrections for the outcome equation. We construct estimators of functionals of interest such as actual and counterfactual distributions of latent and observed outcomes via plug-in rule. We derive functional central limit theorems for all the estimators and show the validity of multiplier bootstrap to carry out functional inference. We apply the methods to wage decompositions in the UK using new data. Here we decompose the diﬀerence between the male and female wage distributions into four eﬀects: composition, wage structure, selection structure and selection sorting. After controlling for endogenous employment selection, we still ﬁnd substantial gender wage gap – ranging from 21\% to 40\% throughout the (latent) oﬀered wage distribution that is not explained by observable labor market characteristics. We also uncover positive sorting for single men and negative sorting for married women that accounts for a substantive fraction of the gender wage gap at the top of the distribution. These ﬁndings can be interpreted as evidence of assortative matching in the marriage market and glass-ceiling in the labor market.},
	language = {en},
	urldate = {2021-05-03},
	journal = {arXiv:1811.11603 [econ, stat]},
	author = {Chernozhukov, Victor and Fernández-Val, Iván and Luo, Siyi},
	month = nov,
	year = {2020},
	keywords = {62P20, 91B40, Economics - Econometrics, Statistics - Methodology},
}

@article{chen_fiscal_nodate,
	title = {Fiscal {Multipliers} and {Regional} {Reallocation}},
	abstract = {Labor reallocation across regions ampli es regional and aggregate scal multipliers. Empirically, I show that regional output, population, and construction display large and lengthy responses to scal stimuli. Theoretically, I develop a multi-region New Keynesian model with labor migration and housing construction and as well as proposing a new method to tractably handle gradual migration in spatial dynamic stochastic general equilibrium (DSGE) models. Quantitatively, I nd that when a national military buildup a ects regions di erentially as in the data, labor reallocation ampli es the aggregate output multiplier by 30 percent. Labor reallocation ampli es regional output through a housing construction boom and aggregate output through a covariance e ect arising from net directed migration towards booming regions.},
	language = {en},
	author = {Chen, Vince W},
	pages = {86},
}

