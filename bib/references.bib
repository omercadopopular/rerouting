@article{lisboa_effects_2010,
	title = {The effects of trade liberalization on productivity growth in {Brazil}: competition or technology?},
	volume = {64},
	issn = {0034-7140, 1806-9134},
	shorttitle = {The effects of trade liberalization on productivity growth in {Brazil}},
	url = {http://www.scielo.br/j/rbe/a/FsvhbQgGGjrvVswSP8q8bKx/},
	doi = {10.1590/S0034-71402010000300004},
	abstract = {This paper examines the effects of trade liberalization on productivity growth in Brazil. In contrast with the previous literature, we examine whether this relationship is driven by product or input market effects, by including both output and input tariffs in firm-level productivity regressions and allowing for imperfect competition in the product market. The results show that the reductions of input tariffs were more important to explain the productivity growth that took place during trade liberalization in Brazil. Moreover, we find that the reduction in input tariffs led to a rise in mark-ups, while the reduction in output tariffs did the opposite.},
	language = {en},
	urldate = {2022-04-27},
