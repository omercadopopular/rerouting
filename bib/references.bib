	author = {Koenig, Pamina},
	month = nov,
	year = {2009},
	keywords = {Destination-specific spillovers, Export decision, Export market},
	pages = {186--195},
}

@article{bohnstedt_spillovers_2016,
	title = {Spillovers from {Foreign} {Exporters}},
	volume = {24},
	copyright = {© 2015 John Wiley \& Sons Ltd},
	issn = {1467-9396},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/roie.12203},
	doi = {10.1111/roie.12203},
	abstract = {We develop a general equilibrium model of international trade with heterogeneous firms that accounts for productivity spillovers transmitted by foreign exporters. Everything else equal, stronger spillovers increase welfare. We embed the model framework into a trade policy scenario where countries strategically set inter-country variable trade costs for the trading partner. In the strategic Nash-equilibrium policy, governments trade-off welfare gains from protectionism and those that are due to spillovers from foreign exporters. The equilibrium degree of protectionism is decreasing in the strength of the spillover. Policy coordination induces welfare gains but these gains can be hump-shaped in the spillover strength.},
	language = {en},
	number = {1},
	urldate = {2025-01-14},
	journal = {Review of International Economics},
	author = {Bohnstedt, Anna},
	year = {2016},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/roie.12203},
	pages = {150--170},
}

@article{ottaviano_agglomeration_2002,
	title = {Agglomeration and {Trade} {Revisited}},
	volume = {43},
	issn = {0020-6598},
	url = {https://www.jstor.org/stable/826994},
	abstract = {The purpose of this article is twofold. First, we present an alternative model of agglomeration and trade that displays the main features of the recent economic geography literature while allowing for the derivation of analytical results by means of simple algebra. Second, we show how this framework can be used to permit (i) a welfare analysis of the agglomeration process, (ii) a full-fledged forward-looking analysis of the role of history and expectations in the emergence of economic clusters, and (iii) a simple analysis of the impact of urban costs on the spatial distribution of economic activities.},
	number = {2},
