	keywords = {Education, Neighborhood Characteristics, Population, Provision and Effects of Welfare Programs, Urban, Rural, Regional, and Transportation Economics: Regional Migration, Public Health, Welfare and Poverty: Government Programs, Public Pensions, Health: Government Policy, Regional Labor Markets, Regulation, State and Local Government: Health, Welfare},
	pages = {118--145},
}

@article{clemens_fiscal_2012,
	title = {Fiscal {Policy} {Multipliers} on {Subnational} {Government} {Spending}},
